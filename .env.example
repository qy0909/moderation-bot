# Discord bot token (Developer Portal → Bot → Reset Token)
DISCORD_TOKEN=your_discord_bot_token_here

# Hugging Face access token (huggingface.co → Settings → Access Tokens)
HF_API_KEY=your_huggingface_api_key_here

# Google Gemini API key (aistudio.google.com → Get API key)
GENERATIVE_AI_API=your_google_gemini_api_key_here

# PostgreSQL password — must match DATABASE_URL below and docker-compose
DB_PASSWORD=your_postgres_password_here

# Async connection string used by the bot
DATABASE_URL=postgresql://postgres:your_postgres_password_here@modbot-postgres:5432/modbot
